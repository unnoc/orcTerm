<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/card_view"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="?attr/colorSurface"
    app:strokeWidth="1dp"
    app:strokeColor="?attr/colorOutline"
    app:cardUseCompatPadding="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Checkbox for selection mode -->
            <CheckBox
                android:id="@+id/checkbox"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

            <!-- OS Icon -->
            <ImageView
                android:id="@+id/iv_os_icon"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_os_linux"
                app:layout_constraintStart_toEndOf="@+id/checkbox"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="@+id/tv_host_detail"
                android:layout_marginEnd="16dp"/>

            <!-- IP Address / Hostname -->
            <TextView
                android:id="@+id/tv_ip"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="192.168.31.81"
                android:textColor="?attr/colorOnSurface"
                android:textSize="16sp"
                android:textStyle="bold"
                android:ellipsize="end"
                android:maxLines="1"
                android:layout_marginStart="16dp"
                app:layout_constraintStart_toEndOf="@+id/iv_os_icon"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/iv_status"
                android:layout_marginEnd="8dp"/>

            <!-- User & Port -->
            <TextView
                android:id="@+id/tv_host_detail"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="user@192.168.31.81:22"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="12sp"
                android:ellipsize="end"
                android:maxLines="1"
                android:layout_marginTop="4dp"
                app:layout_constraintStart_toStartOf="@+id/tv_ip"
                app:layout_constraintTop_toBottomOf="@+id/tv_ip"
                app:layout_constraintEnd_toStartOf="@+id/iv_status"
                android:layout_marginEnd="8dp"/>

            <!-- Status Indicator (Dot) -->
            <ImageView
                android:id="@+id/iv_status"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:src="@drawable/bg_status_indicator"
                app:tint="@color/status_success"
                app:layout_constraintEnd_toStartOf="@+id/btn_more"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="@+id/tv_ip"
                android:layout_marginEnd="8dp"/>

            <!-- More Actions Button -->
            <ImageView
                android:id="@+id/btn_more"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_action_settings"
                app:tint="?attr/colorOnSurfaceVariant"
                android:visibility="gone"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Latency -->
            <TextView
                android:id="@+id/tv_latency"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="9 ms"
                android:textColor="@color/status_success"
                android:textSize="12sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/iv_status"
                app:layout_constraintBaseline_toBaselineOf="@+id/tv_host_detail"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <View
            android:id="@+id/divider_hardware"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?attr/colorOutline"
            android:alpha="0.2"
            android:layout_marginTop="12dp" />

        <!-- Simple Mode Stats -->
        <LinearLayout
            android:id="@+id/ll_hardware_stats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp"
            android:baselineAligned="false">

            <!-- CPU -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:id="@+id/label_cpu"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CPU"
                    android:textSize="10sp"
                    android:textAllCaps="true"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:alpha="0.7"/>
                <TextView
                    android:id="@+id/tv_cores"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="6 Cores"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface"/>
            </LinearLayout>

            <!-- Memory -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:id="@+id/label_mem"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MEM"
                    android:textSize="10sp"
                    android:textAllCaps="true"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:alpha="0.7"/>
                <TextView
                    android:id="@+id/tv_mem_total"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="11.2 G"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface"/>
            </LinearLayout>

            <!-- Storage -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:id="@+id/label_disk"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DISK"
                    android:textSize="10sp"
                    android:textAllCaps="true"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:alpha="0.7"/>
                <TextView
                    android:id="@+id/tv_disk_total"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="69.9 G"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface"/>
            </LinearLayout>

            <!-- Temp -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:id="@+id/label_temp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TEMP"
                    android:textSize="10sp"
                    android:textAllCaps="true"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:alpha="0.7"/>
                <TextView
                    android:id="@+id/tv_temperature"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="45°C"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/status_warning"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Uptime (Hidden by default or managed by adapter) -->
        <TextView
            android:id="@+id/tv_uptime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="Uptime: 10 days"
            android:textSize="10sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:visibility="gone" />

        <!-- Linear Monitor Mode -->
        <LinearLayout
            android:id="@+id/ll_monitor_linear"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="12dp"
            android:visibility="gone">
            
            <!-- CPU -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="40dp"
                    android:layout_height="wrap_content"
                    android:text="CPU"
                    android:textSize="11sp"/>
                <ProgressBar
                    android:id="@+id/progress_cpu_linear"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:progress="45"/>
                <TextView
                    android:id="@+id/tv_cpu_val_linear"
                    android:layout_width="40dp"
                    android:layout_height="wrap_content"
                    android:text="45%"
                    android:gravity="end"
                    android:textSize="11sp"/>
            </LinearLayout>

            <!-- MEM -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="4dp">
                <TextView
                    android:layout_width="40dp"
                    android:layout_height="wrap_content"
                    android:text="MEM"
                    android:textSize="11sp"/>
                <ProgressBar
                    android:id="@+id/progress_mem_linear"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:progress="60"/>
                <TextView
                    android:id="@+id/tv_mem_val_linear"
                    android:layout_width="40dp"
                    android:layout_height="wrap_content"
                    android:text="60%"
                    android:gravity="end"
                    android:textSize="11sp"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tv_net_linear"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="↑ 10KB/s  ↓ 20KB/s"
                android:textSize="10sp"
                android:gravity="center_horizontal"
                android:layout_marginTop="4dp"/>
             <TextView
                android:id="@+id/tv_disk_linear"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="R: 1MB/s  W: 0.5MB/s"
                android:textSize="10sp"
                android:gravity="center_horizontal"/>
        </LinearLayout>

        <!-- Digital Monitor Mode -->
        <LinearLayout
            android:id="@+id/ll_monitor_digital"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp"
            android:visibility="gone">
            <TextView
                android:id="@+id/tv_cpu_digital"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="CPU: 45%"
                android:textSize="12sp"
                android:gravity="center"/>
            <TextView
                android:id="@+id/tv_mem_digital"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="MEM: 60%"
                android:textSize="12sp"
                android:gravity="center"/>
             <TextView
                android:id="@+id/tv_net_digital"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="NET: 30K"
                android:textSize="12sp"
                android:gravity="center"/>
             <TextView
                android:id="@+id/tv_disk_digital"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="IO: 1.5M"
                android:textSize="12sp"
                android:gravity="center"/>
        </LinearLayout>

        <!-- Ring/Chart Monitor Mode -->
        <LinearLayout
            android:id="@+id/ll_monitor_ring"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp"
            android:visibility="gone">
            
            <com.github.mikephil.charting.charts.PieChart
                android:id="@+id/chart_cpu_ring"
                android:layout_width="60dp"
                android:layout_height="60dp" />
            
            <com.github.mikephil.charting.charts.PieChart
                android:id="@+id/chart_mem_ring"
                android:layout_width="60dp"
                android:layout_height="60dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center_vertical|end">
                <TextView
                    android:id="@+id/tv_net_up"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="↑ 10KB/s"
                    android:textSize="10sp"/>
                <TextView
                    android:id="@+id/tv_net_down"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="↓ 20KB/s"
                    android:textSize="10sp"/>
                <TextView
                    android:id="@+id/tv_disk_read"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="R: 1MB/s"
                    android:textSize="10sp"/>
                <TextView
                    android:id="@+id/tv_disk_write"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="W: 0.5MB/s"
                    android:textSize="10sp"/>
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
