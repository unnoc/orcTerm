<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp">

    <ImageView
        android:id="@+id/empty_state_icon"
        android:layout_width="96dp"
        android:layout_height="96dp"
        android:src="@drawable/ic_action_terminal"
        android:alpha="0.5"
        android:contentDescription="@null"
        app:tint="?attr/colorOnSurfaceVariant"
        xmlns:app="http://schemas.android.com/apk/res-auto" />

    <TextView
        android:id="@+id/empty_state_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/session_empty_terminal"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="?attr/colorOnSurface"
        android:gravity="center" />

    <TextView
        android:id="@+id/empty_state_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Connect to a host to start a new session"
        android:textSize="14sp"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:gravity="center" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/empty_state_action"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Connect Host"
        style="@style/Widget.Material3.Button.TonalButton" />

</LinearLayout>
